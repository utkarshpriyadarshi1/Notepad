{
  "name": "smritipatra-desktop",
  "version": "1.0.2",
  "description": "Offline sticky notes and task management widgets",
  "main": "backend/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on -t 5000 http://127.0.0.1:5173 && cross-env NODE_ENV=development electron ../backend/main.js\"",
    "build": "vite build",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.smritipatra.desktop",
    "productName": "Smritipatra",
    "files": [
      "dist/**/*",
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!assets/**/*"
        ]
      },
      {
        "from": "../app.config.json",
        "to": "app.config.json"
      },
      "public/sql-wasm.wasm"
    ],
    "extraResources": [
      {
        "from": "../backend/assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../docs/help",
        "to": "docs/help"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../backend/assets/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "../backend/assets/taskbar-icon.png",
      "category": "public.app-category.productivity"
    }
  }
}