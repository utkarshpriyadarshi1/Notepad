{
  "name": "stickyflow-desktop",
  "version": "1.0.0",
  "description": "Offline sticky notes and task management widgets",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on -t 5000 http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "package": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.0.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.stickyflow.taskcore",
    "productName": "StickyFlow Desktop",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "app.config.js",
      "public/sql-wasm.wasm"
    ],
    "extraResources": [
      {
        "from": "electron/assets",
        "to": "assets",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/taskbar-icon.png",
      "category": "public.app-category.productivity"
    }
  }
}